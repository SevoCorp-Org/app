# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Environment variables (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ─── Next.js build output ─────────────────────────────────────────────────────
.next/
out/
dist/

# ─── Prisma generated client ──────────────────────────────────────────────────
# (regenerated from schema.prisma on each machine via `prisma generate`)
# Comment this out if you want to commit the generated client
node_modules/.prisma/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Misc ─────────────────────────────────────────────────────────────────────
.vercel
*.tsbuildinfo
next-env.d.ts
